{
  "name": "the-new-magic-dj",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered DJ platform with futuristic glass morphism design and Spotify integration",
  "author": "LiyamFlx",
  "license": "MIT",
  "homepage": "https://github.com/LiyamFlx/TheNewMagicDJ#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/LiyamFlx/TheNewMagicDJ.git"
  },
  "bugs": {
    "url": "https://github.com/LiyamFlx/TheNewMagicDJ/issues"
  },
  "keywords": [
    "dj",
    "ai",
    "music",
    "spotify",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "glass-morphism",
    "futuristic-ui",
    "vercel",
    "serverless"
  ],
  "scripts": {
    "test": "echo \"No test suite defined yet\" && exit 0",
    "dev": "vite --host",
    "dev:api": "vercel dev",
    "build": "tsc && vite build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist/assets/*.js",
    "build:vercel": "vercel build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit --project api/tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --max-warnings 0",
    "lint:api": "eslint api/**/*.ts --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"api/**/*.{ts,js,json}\" \"utils/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"api/**/*.{ts,js,json}\" \"utils/**/*.{ts,js,json}\"",
    "clean": "rm -rf dist .vercel node_modules/.vite",
    "clean:all": "rm -rf dist .vercel node_modules node_modules/.vite && npm install",
    "start": "npm run preview",
    "api:test": "node --loader ts-node/esm test/api/test-spotify-token.ts",
    "api:health": "curl -s http://localhost:3000/api/spotify-token?health=true | jq || curl -s http://localhost:3000/api/spotify-token?health=true",
    "test:build": "npm run typecheck && npm run typecheck:api && npm run build",
    "test:api": "npm run api:test",
    "deploy": "npm run test:build && vercel --prod",
    "deploy:preview": "vercel",
    "ops:env": "bash scripts/ops/verify-vercel-env.sh",
    "ops:health": "curl -s ${VERCEL_URL:-http://localhost:5174}/api/health | jq || curl -s ${VERCEL_URL:-http://localhost:5174}/api/health",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:headed": "npx playwright test --headed",
    "test:qa": "npx playwright test --grep @qa-validation",
    "test:qa:headed": "npx playwright test --grep @qa-validation --headed",
    "test:install": "npx playwright install",
    "test:install-deps": "npx playwright install-deps",
    "env:check": "node -e \"console.log('Spotify Client ID:', (process.env.SPOTIFY_CLIENT_ID||process.env.VITE_SPOTIFY_CLIENT_ID) ? 'Set' : 'Missing'); console.log('Spotify Secret:', (process.env.SPOTIFY_CLIENT_SECRET||process.env.VITE_SPOTIFY_CLIENT_SECRET) ? 'Set' : 'Missing');\"",
    "validate": "npm run typecheck && npm run typecheck:api && npm run lint && npm run format:check && npm run test:build"
  },
  "dependencies": {
    "@googleapis/youtube": "^29.0.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/react-router-dom": "^5.3.3",
    "commander": "^14.0.1",
    "lucide-react": "^0.544.0",
    "node-youtube-music": "^0.10.3",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vercel/node": "^5.3.22",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^16.4.0",
    "got": "^14.4.9",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "rollup": "^4.52.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.44.0",
    "vercel": "^48.0.3",
    "vite": "^7.1.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.52.0",
    "@rollup/rollup-linux-x64-gnu": "^4.52.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "18.19.0",
    "npm": "10.2.3"
  }
}
