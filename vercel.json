{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\..*)","dest": "/$1" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
